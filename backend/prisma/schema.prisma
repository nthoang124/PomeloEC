generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique @db.VarChar(255)
  phone         String?  @unique @db.VarChar(20)
  role          UserRole @default(BUYER)
  loyalty_coins Int      @default(0)
  created_at    DateTime @default(now())

  // Relations
  addresses Address[]
  orders    Order[]
  store     Store?
}

enum UserRole {
  BUYER
  SELLER
  ADMIN
}

model Address {
  id            String  @id @default(uuid()) @db.Uuid
  user_id       String  @db.Uuid
  user          User    @relation(fields: [user_id], references: [id])
  full_name     String  @db.VarChar(100)
  phone         String  @db.VarChar(20)
  province      String  @db.VarChar(100)
  district      String  @db.VarChar(100)
  ward          String  @db.VarChar(100)
  exact_address String  @db.VarChar(255)
  is_default    Boolean @default(false)
}

model Store {
  id                String      @id @default(uuid()) @db.Uuid
  owner_id          String      @unique @db.Uuid
  owner             User        @relation(fields: [owner_id], references: [id])
  name              String      @db.VarChar(100)
  available_balance Decimal     @default(0.0) @db.Decimal(15, 2)
  escrow_balance    Decimal     @default(0.0) @db.Decimal(15, 2)
  status            StoreStatus @default(PENDING)

  products             Product[]
  sub_orders           SubOrder[]
  seller_profile       SellerProfile?
  wallet_transactions  WalletTransaction[]
}

enum StoreStatus {
  PENDING
  VERIFIED
  BANNED
}

model SellerProfile {
  id                   String   @id @default(uuid()) @db.Uuid
  store_id             String   @unique @db.Uuid
  store                Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  identity_card_url    String   @db.VarChar(500)
  business_license_url String?  @db.VarChar(500)
  tax_code             String?  @db.VarChar(50)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
}


// ------ CATALOG MODULE ------

model Category {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     @db.VarChar(100)
  parent_id String?    @db.Uuid
  parent    Category?  @relation("CategoryToCategory", fields: [parent_id], references: [id])
  children  Category[] @relation("CategoryToCategory")

  products Product[]
}

model Brand {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique @db.VarChar(100)

  products Product[]
}

model Product {
  id          String    @id @default(uuid()) @db.Uuid
  store_id    String    @db.Uuid
  store       Store     @relation(fields: [store_id], references: [id])
  category_id String?   @db.Uuid
  category    Category? @relation(fields: [category_id], references: [id])
  brand_id    String?   @db.Uuid
  brand       Brand?    @relation(fields: [brand_id], references: [id])
  name        String    @db.VarChar(255)
  base_price  Decimal   @db.Decimal(15, 2)
  description String?   @db.Text

  images     ProductImage[]
  attributes ProductAttribute[]
  variants   Variant[]

  @@index([store_id])
}

model ProductImage {
  id         String  @id @default(uuid()) @db.Uuid
  product_id String  @db.Uuid
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  url        String  @db.VarChar(500)
  is_primary Boolean @default(false)
}

// Định nghĩa Cột phân cực (Ví dụ: Color, Size)
model ProductAttribute {
  id         String                  @id @default(uuid()) @db.Uuid
  product_id String                  @db.Uuid
  product    Product                 @relation(fields: [product_id], references: [id], onDelete: Cascade)
  name       String                  @db.VarChar(50)
  values     ProductAttributeValue[]
}

// Lưu trữ Giá trị (Ví dụ: Red, Có viền, L)
model ProductAttributeValue {
  id           String           @id @default(uuid()) @db.Uuid
  attribute_id String           @db.Uuid
  attribute    ProductAttribute @relation(fields: [attribute_id], references: [id], onDelete: Cascade)
  value        String           @db.VarChar(50)

  variant_mappings VariantAttributeMapping[]
}

// Mã Lưu kho SKU thực tế - Biến Thể Tổ Hợp Chập
model Variant {
  id             String  @id @default(uuid()) @db.Uuid
  product_id     String  @db.Uuid
  product        Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  sku            String  @unique @db.VarChar(50)
  stock_quantity Int     @default(0)
  price          Decimal @db.Decimal(15, 2)

  attribute_mappings VariantAttributeMapping[]
  order_items        OrderItem[]
  inventory_ledgers  InventoryLedger[]

  @@index([product_id])
}

// Link trung gian nối SKU Variant với Các Giá trị thuôc tính (Nhiều nhiều)
model VariantAttributeMapping {
  variant_id         String                @db.Uuid
  variant            Variant               @relation(fields: [variant_id], references: [id], onDelete: Cascade)
  attribute_value_id String                @db.Uuid
  attribute_value    ProductAttributeValue @relation(fields: [attribute_value_id], references: [id], onDelete: Cascade)

  @@id([variant_id, attribute_value_id])
}

// ------ ORDER MODULE ------

model Order {
  id           String      @id @default(uuid()) @db.Uuid
  buyer_id     String      @db.Uuid
  buyer        User        @relation(fields: [buyer_id], references: [id])
  status       OrderStatus @default(PENDING_PAYMENT)
  total_amount Decimal     @db.Decimal(15, 2)
  created_at   DateTime    @default(now())

  sub_orders SubOrder[]
  payments   Payment[]

  @@index([buyer_id, created_at])
  @@index([status])
}

model SubOrder {
  id              String      @id @default(uuid()) @db.Uuid
  order_id        String      @db.Uuid
  order           Order       @relation(fields: [order_id], references: [id], onDelete: Cascade)
  store_id        String      @db.Uuid
  store           Store       @relation(fields: [store_id], references: [id])
  status          OrderStatus @default(PENDING_PAYMENT)
  total_amount    Decimal     @db.Decimal(15, 2)
  shipping_fee    Decimal     @default(0) @db.Decimal(15, 2)
  tracking_number String?     @db.VarChar(100)

  items OrderItem[]

  @@index([order_id])
  @@index([store_id])
  @@index([tracking_number])
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELED
}

model OrderItem {
  id           String   @id @default(uuid()) @db.Uuid
  sub_order_id String   @db.Uuid
  sub_order    SubOrder @relation(fields: [sub_order_id], references: [id], onDelete: Cascade)
  variant_id   String   @db.Uuid
  variant      Variant  @relation(fields: [variant_id], references: [id])
  quantity     Int
  unit_price   Decimal  @db.Decimal(15, 2)

  @@index([sub_order_id])
}

// ------ PAYMENT MODULE ------

model Payment {
  id         String        @id @default(uuid()) @db.Uuid
  order_id   String        @db.Uuid
  order      Order         @relation(fields: [order_id], references: [id], onDelete: Cascade)
  amount     Decimal       @db.Decimal(15, 2)
  method     PaymentMethod @default(VNPAY)
  status     PaymentStatus @default(PENDING)
  txn_ref    String?       @unique @db.VarChar(100) // Mã giao dịch của Cổng thanh toán
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt
}

enum PaymentMethod {
  COD
  VNPAY
  MOMO
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ------ INVENTORY MODULE ------

model InventoryLedger {
  id               String          @id @default(uuid()) @db.Uuid
  variant_id       String          @db.Uuid
  variant          Variant         @relation(fields: [variant_id], references: [id])
  quantity_change  Int // Số dương (Nhập hàng, Khách hoàn trả), Số âm (Khách mua, Xuất hủy)
  transaction_type TransactionType
  reference_id     String?         @db.Uuid // ID của Đơn hàng (Order) hoặc Đơn nhập (Import)
  created_at       DateTime        @default(now())

  @@index([variant_id])
  @@index([reference_id])
}

enum TransactionType {
  IMPORT // Nhập kho
  SALE // Bán hàng (Checkout)
  RETURN // Khách trả hàng
  ADJUSTMENT // Điều chỉnh (Hư hỏng, Thất thoát)
}

// ------ WALLET MODULE ------

model WalletTransaction {
  id                 String             @id @default(uuid()) @db.Uuid
  store_id           String             @db.Uuid
  store              Store              @relation(fields: [store_id], references: [id])
  amount             Decimal            @db.Decimal(15, 2)
  transaction_type   WalletTxType
  reference_order_id String?            @db.Uuid
  description        String?            @db.VarChar(255)
  created_at         DateTime           @default(now())

  @@index([store_id])
  @@index([reference_order_id])
}

enum WalletTxType {
  ESCROW_LOCK      // Khóa tiền khi khách mua hàng
  ESCROW_RELEASE   // Mở khóa tiền khi đơn hàng hoàn thành
  PLATFORM_FEE     // Trừ phí nền tảng
  WITHDRAWAL       // Rút tiền về ngân hàng
}
